# ═══════════════════════════════════════════════════
# Bharat News Hub — Environment Variables Template
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your real keys.
# cp .env.example .env

# ── TruthLens AI Keys ──
VITE_OPENROUTER_TRUTHLENS_KEY=your_openrouter_truthlens_key_here
VITE_GROQ_API_KEY=your_groq_api_key_here
VITE_HUGGINGFACE_TOKEN=your_huggingface_token_here
VITE_NEWSAPI_TRUTHLENS_KEY=your_newsapi_truthlens_key_here

# ── Article Generation (OpenRouter / Gemini) ──
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── News Feed Keys ──
VITE_GNEWS_API_KEY_1=your_gnews_key_1
VITE_GNEWS_API_KEY_2=your_gnews_key_2
VITE_GNEWS_API_KEY_3=your_gnews_key_3
VITE_NEWSAPI_KEY=your_newsapi_key_here
VITE_NEWSDATA_API_KEY=your_newsdata_key_here

# ── Supabase n8n Cache ──
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── ScraperAPI ──
VITE_SCRAPER_API_KEY=your_scraper_api_key_here

# ── Unsplash ──
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── Firebase ──
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
